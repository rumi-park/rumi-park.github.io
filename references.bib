  file = {/Users/rumi-park/Zotero/storage/5JBWURRF/Hartl and Singh - 2019 - Local Shtukas and Divisible Local Anderson Modules.pdf;/Users/rumi-park/Zotero/storage/X2PU8VD7/Hartl and Singh - 2019 - Local Shtukas and Divisible Local Anderson Modules.pdf}
