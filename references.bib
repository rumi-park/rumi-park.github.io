@article{Haines2009,
  title = {The Base Change Fundamental Lemma for Central Elements in Parahoric {{Hecke}} Algebras},
  author = {Haines, Thomas J.},
  year = 2009,
  month = sep,
  journal = {Duke Mathematical Journal},
  volume = {149},
  number = {3},
  eprint = {0808.3426},
  primaryclass = {math},
  issn = {0012-7094},
  doi = {10.1215/00127094-2009-045},
  urldate = {2026-02-02},
  abstract = {Let G be an unramified group over a p-adic field F , and let E/F be a finite unramified extension field. Let \texttheta{} denote a generator of Gal(E/F ). This paper concerns the matching, at all semi-simple elements, of orbital integrals on G(F ) with \texttheta -twisted orbital integrals on G(E). More precisely, suppose {$\varphi$} belongs to the center of a parahoric Hecke algebra for G(E). This paper introduces a base change homomorphism {$\varphi$} 7{$\rightarrow$} b{$\varphi$} taking values in the center of the corresponding parahoric Hecke algebra for G(F ). It proves that the functions {$\varphi$} and b{$\varphi$} are associated, in the sense that the stable orbital integrals (for semi-simple elements) of b{$\varphi$} can be expressed in terms of the stable twisted orbital integrals of {$\varphi$}. In the special case of spherical Hecke algebras (which are commutative) this result becomes precisely the base change fundamental lemma proved previously by Clozel [Cl90] and Labesse [Lab90]. As has been explained in [H05], the fundamental lemma proved in this paper is a key ingredient for the study of Shimura varieties with parahoric level structure at the prime p.},
  archiveprefix = {arXiv},
  langid = {english},
  keywords = {Mathematics - Number Theory,Mathematics - Representation Theory},
  file = {/Users/rumi-park/Zotero/storage/77M2MYU3/Haines - 2009 - The base change fundamental lemma for central elements in parahoric Hecke algebras.pdf}
}

