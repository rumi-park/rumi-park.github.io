  number = {arXiv:2205.10344},
  eprint = {2205.10344},
  primaryclass = {math},
  publisher = {arXiv},
  doi = {10.48550/arXiv.2205.10344},
  urldate = {2026-02-02},
  abstract = {We prove the Hecke orbit conjecture of Chai--Oort for Shimura varieties of Hodge type at odd primes of good reduction. We use a novel result for the local monodromy groups of F isocrystals ``coming from geometry'', which refines Crew's parabolicity conjecture. In the course of the proof, we also introduce a noncommutative generalisation of Serre--Tate coordinates for formal neighbourhoods of central leaves, built upon the previous work of Caraiani---Scholze and Kim. Using these coordinates, we reinterpret Chai--Oort's notion of strongly Tate-linear subspaces and we establish upper bounds for their monodromy groups. For this step, we employ the notion of Cartier--Witt stacks, as introduced by Drinfeld and Bhatt--Lurie. Another crucial ingredient in the proof is a rigidity result proved by Chai--Oort, which shows that the relevant subspaces are strongly Tate-linear. On the way, we generalise de Jong's full faithfulness theorem for F -isocrystals.},
  archiveprefix = {arXiv},
  langid = {english},
  keywords = {Mathematics - Algebraic Geometry,Mathematics - Number Theory},
  file = {/Users/rumi-park/Zotero/storage/A2JE8IV5/D'Addezio and Hoften - 2025 - Hecke orbits on Shimura varieties of Hodge type.pdf}
